(begin (use-modules (guix build gnu-build-system) (guix build utils)) (begin (define %build-inputs (quote (("source" . "/nix/store/qjnj9ca8hck4cshz9qhpdh5l5kz7is9l-mailutils-3.20.tar.zst") ("autoconf" . "/nix/store/wih2f1xczh9nld9m6182p8jh0vjgdx37-autoconf-2.69") ("automake" . "/nix/store/5vf0023zjv9n8g1hxxp79nx8f1dafgs4-automake-1.17") ("gettext" . "/nix/store/jddnixds7aqrpqhd8gw4vyqh88a5m9pp-gettext-minimal-0.23.1") ("libtool" . "/nix/store/zrl81sh9s909k6216dsgf9y5dckd7i18-libtool-2.4.7") ("m4" . "/nix/store/1n0yyh1q15n681330wy0nzmh9zx7b98i-m4-1.4.19") ("perl" . "/nix/store/2030dfdaq5i1d7wiq0yn20vg8pg239jw-perl-5.36.0") ("texinfo" . "/nix/store/9i97qhm3rds0xay4xb4v2580lidr7nil-texinfo-6.8") ("dejagnu" . "/nix/store/gw7hvzpv5fj5yffxla18d3nnw0k38iz6-dejagnu-1.6.3") ("guile" . "/nix/store/d69gxqa3b90rqfg4g2v1zgap72n7apxw-guile-3.0.9") ("gsasl" . "/nix/store/qik995iqhll6x78kpjvl5a3n80jg18w7-gsasl-2.2.2") ("gnutls" . "/nix/store/hv29rc73bbkj11yn1wfdfjn9lm8apyaj-gnutls-3.8.3") ("ncurses" . "/nix/store/app6ryybbpvxlmhfviy5ilh2qsxnml5d-ncurses-6.2.20210619") ("readline" . "/nix/store/i0yfb4lwy8ndgq8q44a3fy1p4rpk5sp3-readline-8.2.13") ("linux-pam" . "/nix/store/ln8inrsavq94igv372dfn3a3m14g1jgq-linux-pam-1.5.2") ("libltdl" . "/nix/store/7y5wfvrqc1rdq38fv0q7757xicd7hd8p-libltdl-2.4.7") ("libxcrypt" . "/nix/store/fshsgqg4h5bww60p6asrc9cbbsardmnh-libxcrypt-4.4.38") ("gdbm" . "/nix/store/lgdk60853kaba70jfhp2l4ib2l0x0hxk-gdbm-1.25") ("libunistring" . "/nix/store/vvdbr5l0wii2zn12x2x7mk3dys292lsk-libunistring-1.3") ("tar" . "/nix/store/ib2drldkmhwjdsfsr8a61w2land04b4z-tar-1.35") ("gzip" . "/nix/store/9nwr1gx9a6sd5wq8833a6hrqp7klvgfx-gzip-1.14") ("bzip2" . "/nix/store/nispp88v246z3gbxb0khg7qmhlqsgmr6-bzip2-1.0.8") ("file" . "/nix/store/6h5i05aqb91qv0xrymhx5n0sxhp88a1b-file-5.46") ("diffutils" . "/nix/store/qbdg2k6k59ic660lfigbasa2ksgy7s4g-diffutils-3.12") ("patch" . "/nix/store/s12gja7ydc1gcrfppcpd3qw9p765qi0p-patch-2.7.6") ("findutils" . "/nix/store/z48pja36xgl8cq12ffayj3m0irmrwsm