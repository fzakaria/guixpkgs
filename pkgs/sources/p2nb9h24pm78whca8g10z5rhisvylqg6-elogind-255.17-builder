(begin (use-modules (guix build meson-build-system) (guix build utils)) (define build-phases (modify-phases (modify-phases %standard-phases (add-after (quote unpack) (quote patch-tzdata) (lambda* (#:key native-inputs inputs #:allow-other-keys) (substitute* "src/basic/time-util.c" (("/usr/share/zoneinfo") (search-input-directory (or native-inputs inputs) "share/zoneinfo"))))) (add-after (quote unpack) (quote do-not-install-empty-/var/log/elogind-dir) (lambda _ (substitute* "meson.build" (("install_emptydir\\(elogindstatedir)") "")))) (add-after (quote unpack) (quote fix-pkttyagent-path) (lambda _ (substitute* "meson.build" (("bindir / 'pkttyagent'") "'/run/current-system/profile/bin/pkttyagent'")))) (add-after (quote unpack) (quote use-global-hook-directory) (lambda _ (substitute* (list "src/login/logind-core.c" "src/login/logind-dbus.c" "src/sleep/sleep.c" "src/shared/sleep-config.c") (("PKGSYSCONFDIR") "\"/etc/elogind\"")))) (add-after (quote unpack) (quote adjust-tests) (lambda _ (substitute* (quote ("src/test/test-xattr-util.c" "src/test/test-copy.c" "src/test/test-fs-util.c")) (("/var/tmp/") "/tmp/")) (substitute* "src/test/test-xattr-util.c" (("fd, \"usr\", \"user.idontexist\"") "fd, \"/tmp\", \"user.idontexist\"")) (substitute* (quote ("src/test/test-chase.c" "src/test/test-fd-util.c")) (("/usr") "/tmp") (("\"usr\"") "\"tmp\"")) (substitute* "src/test/meson.build" ((".*'test-cgroup-util\\.c'.*") "") ((".*'test-mountpoint-util\\.c'.*") "")) (substitute* "src/libelogind/meson.build" ((".*'sd-bus/test-bus-creds.c'.*") "") ((".*'sd-login/test-login.c'.*") "") ((".*'sd-device/test-sd-device.c'.*") "")) (substitute* "src/test/test-copy.c" (("/usr/lib/os-release") "/etc/passwd")) (substitute* "src/test/test-exec-util.c" (("#!/bin/sh") (string-append "#!" (which "sh")))) (substitute* "src/test/test-fs-util.c" (("usr") "etc") (("/etc/machine-id") "/etc/passwd")) (substitute* "src/test/test-id128.c" (("if \\(r == -EOPNOTSUPP\\)") "if (1)")) (substitute* "src/test/test-m