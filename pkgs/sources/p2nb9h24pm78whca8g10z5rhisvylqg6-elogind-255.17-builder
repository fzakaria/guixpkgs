) (define %output (assoc-ref %outputs "out")) (meson-build #:source "/nix/store/sii7ya2f6xyap1j5lhnlr8cx9yrbp6mx-elogind-255.17-checkout" #:system "x86_64-linux" #:outputs %outputs #:inputs %build-inputs #:search-paths (quote (("PKG_CONFIG_PATH" ("lib/pkgconfig" "lib64/pkgconfig" "share/pkgconfig") ":" directory #f) ("GUIX_PYTHONPATH" ("lib/python3.11/site-packages") ":" directory #f) ("PYTHONTZPATH" ("share/zoneinfo") ":" directory #f) ("SGML_CATALOG_FILES" ("sgml") ":" regular "^catalog$|^CATALOG$|^.*\\.cat$") ("XML_CATALOG_FILES" ("xml") " " regular "^catalog\\.xml$") ("UDEV_HWDB_PATH" ("lib/udev/hwdb.d") ":" directory #f) ("BASH_LOADABLES_PATH" ("lib/bash") ":" directory #f) ("C_INCLUDE_PATH" ("include") ":" directory #f) ("CPLUS_INCLUDE_PATH" ("include/c++" "include") ":" directory #f) ("OBJC_INCLUDE_PATH" ("include") ":" directory #f) ("OBJCPLUS_INCLUDE_PATH" ("include/c++" "include") ":" directory #f) ("LIBRARY_PATH" ("lib" "lib64") ":" directory #f) ("GUIX_LOCPATH" ("lib/locale") ":" directory #f) ("TZDIR" ("share/zoneinfo") #f directory #f))) #:phases build-phases #:configure-flags (let* ((out ((@ (guile) getenv) "out")) (sysconf (string-append out "/etc")) (libexec (string-append out "/libexec/elogind")) (dbus-data (string-append out "/share/dbus-1")) (dbuspolicy (string-append dbus-data "/system.d")) (dbussystemservice (string-append dbus-data "/system-services")) (kexec-tools "/nix/store/0pa72b3z4jb91x7ihvzw0wa0dxkdsh6i-kexec-tools-2.0.31") (shadow "/nix/store/hpnvhy86mfjwa60xwk8m5jpmj3pdi4zd-shadow-4.13") (shepherd "/nix/store/wscr5c28qki21j8i1wcx53dcg3hjdz51-shepherd-0.10.5") (halt-path (string-append shepherd "/sbin/halt")) (kexec-path (string-append kexec-tools "/sbin/kexec")) (nologin-path (string-append shadow "/sbin/nologin")) (poweroff-path (string-append shepherd "/sbin/shutdown")) (reboot-path (string-append shepherd "/sbin/reboot"))) (list "-Dmode=release" (string-append "-Dlibexecdir=" libexec) (string-append "-Dsysconfdir=" sysconf) (string-