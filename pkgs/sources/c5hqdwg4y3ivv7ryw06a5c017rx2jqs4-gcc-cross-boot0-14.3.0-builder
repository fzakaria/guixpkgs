output-to-file stage-wrapper (lambda _ (format #t "#! ~a/bin/bash\nexec \"$@\"     -Wno-error=implicit-function-declaration" bash))) (chmod stage-wrapper 365) (cond (#f (setenv "CC_FOR_BUILD" wrapper)) (else (setenv "CC" wrapper) (setenv "STAGE_CC_WRAPPER" stage-wrapper)))))) (add-before (quote configure) (quote pre-configure) (lambda* (#:key inputs outputs #:allow-other-keys) (let ((libdir (or (assoc-ref outputs "lib") (assoc-ref outputs "out"))) (libc (assoc-ref inputs "libc"))) (when libc (for-each (lambda (x) (substitute* (find-files "gcc/config" "^(linux|gnu|sysv4)(64|-elf|-eabi)?\\.h$") (("(#define (GLIBC|GNU_USER)_DYNAMIC_LINKER.*)\\\\\n$" _ line) line))) (quote (1 2 3))) (substitute* (find-files "gcc/config" "^(linux|gnu|sysv4)(64|-elf|-eabi)?\\.h$") (("#define (GLIBC|GNU_USER)_DYNAMIC_LINKER([^ \t]*).*$" _ gnu-user suffix) (format #f "#define ~a_DYNAMIC_LINKER~a \"~a\"~%" gnu-user suffix (string-append libc "/lib/ld-linux-x86-64.so.2")))) (substitute* (find-files "gcc/config" "^gnu-user.*\\.h$") (("#define GNU_USER_TARGET_LIB_SPEC (.*)$" _ suffix) (format #f "#define GNU_USER_TARGET_LIB_SPEC \"-L~a/lib %{!static:-rpath=~a/lib %{!static-libgcc:-rpath=~a/lib -lgcc_s}} \" ~a" libc libc libdir suffix)) (("#define GNU_USER_TARGET_STARTFILE_SPEC.*$" line) (format #f "#define STANDARD_STARTFILE_PREFIX_1 \"~a/lib/\"\n#define STANDARD_STARTFILE_PREFIX_2 \"\"\n~a" libc line))) (substitute* "gcc/config/rs6000/sysv4.h" (("#define LIB_LINUX_SPEC (.*)$" _ suffix) (format #f "#define LIB_LINUX_SPEC \"-L~a/lib %{!static:-rpath=~a/lib %{!static-libgcc:-rpath=~a/lib -lgcc_s}} \" ~a" libc libc libdir suffix)) (("#define\tSTARTFILE_LINUX_SPEC.*$" line) (format #f "#define STANDARD_STARTFILE_PREFIX_1 \"~a/lib/\"\n#define STANDARD_STARTFILE_PREFIX_2 \"\"\n~a" libc line)))) (when (file-exists? "gcc/config/rs6000") (substitute* (find-files "gcc/config/rs6000") (("/lib64") "/lib"))) (substitute* "fixincludes/fixincl.x" (("static char const sed_cmd_z\\[\\] =.*;") "static char const sed_cmd_z[] = \"sed\";")) (when (file-exists? "gcc/config/aarch64") (substitute* "gcc/config/aarch64/t-aarch64-linux" (("lib64") "lib"))) (when (file-exists? "gcc/config/riscv") (substitute* (quote ("gcc/config/riscv/linux.h" "gcc/config/riscv/riscv.h")) (("define STARTFILE_PREFIX_SPEC") "define __STARTFILE_PREFIX_SPEC"))) (when (file-exists? "libbacktrace") (substitute* "libbacktrace/configure" (("WARN_FLAGS=(.*)-Werror" _ flags) (string-append "WARN_FLAGS=" flags))) (when (file-exists? "libsanitizer/libbacktrace") (substitute* "libsanitizer/libbacktrace/Makefile.in" (("-Werror") "")))) (substitute* "libstdc++-v3/src/Makefile.in" (("^OPT_LDFLAGS = ") "OPT_LDFLAGS = -Wl,-rpath=$(libdir) ")) (substitute* "libstdc++-v3/python/Makefile.in" (("pythondir = .*$") (string-append "pythondir = " libdir "/share" "/gcc-$(gcc_version)/python\n"))) (substitute* "gcc/config.in" (("PREFIX_INCLUDE_DIR") "PREFIX_INCLUDE_DIR_isnt_necessary_here"))))) (add-after (quote configure) (quote post-configure) (lambda _ (substitute* "Makefile" (("^TOPLEVEL_CONFIGURE_ARGUMENTS=(.*)$" _ rest) "TOPLEVEL_CONFIGURE_ARGUMENTS=\n"))))) (add-before (quote configure) (quote pre-x86-configure) (lambda _ (substitute* (quote ("gcc/config/i386/t-linux64" "gcc/config/i386/t-gnu64")) (("\\.\\./lib64") "../lib"))))) (add-after (quote unpack) (quote unpack-gmp&co) (lambda* (#:key inputs #:allow-other-keys) (let ((gmp (assoc-ref %build-inputs "gmp-source")) (mpfr (assoc-ref %build-inputs "mpfr-source")) (mpc (assoc-ref %build-inputs "mpc-source"))) (for-each (lambda (source) (invoke "tar" "xvf" source)) (list gmp mpfr mpc)) (symlink "gmp-6.0.0" "gmp") (symlink "mpfr-4.2.2" "mpfr") (symlink "mpc-1.3.1" "mpc")))) (add-after (quote unpack) (quote patch-system.h) (lambda _ (substitute* "gcc/system.h" (("#ifndef SIZE_MAX" all) (string-append "#define SIZE_MAX (ULONG_MAX)\n" all))))) (add-before (quote configure) (quote fix-libcc1) (lambda* (#:key inputs #:allow-other-keys) (substitute* "libcc1/Makefile.in" (("la_LD