(begin (define %build-inputs (quote (("binutils" . "/nix/store/xr43qspq9snl4h5fwvn2r0dpbf1nw605-binutils-cross-boot0-2.44") ("gcc" . "/nix/store/pc091c4jxd8yxrsfjfjrvihv35vsczgg-gcc-cross-boot0-14.3.0") ("libc" . "/nix/store/aqclhjm3a4wxwbs26jh0aaxjqlqpq46w-glibc-2.41") ("bash" . "/nix/store/b8aim6wgicfd29hrn1ynldgrmrzkd1cz-bash-mesboot-5.2.37") ("kernel-headers" . "/nix/store/6c6wf2dw5d6wxmamsvc64hkfgl8yr74y-linux-libre-headers-6.12.17")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let* ((binutils (assoc-ref %build-inputs "binutils")) (gcc (assoc-ref %build-inputs "gcc")) (libc (assoc-ref %build-inputs "libc")) (bash (assoc-ref %build-inputs "bash")) (out (assoc-ref %outputs "out")) (bindir (string-append out "/bin")) (triplet "x86_64-guix-linux-gnu")) (define (wrap-program program) (call-with-output-file program (lambda (p) (format p "#!~a/bin/bash\nexec ~a/bin/~a-~a -B~a/lib -Wl,-dynamic-linker -Wl,~a/~a \"$@\"~%" bash gcc triplet program libc libc "/lib/ld-linux-x86-64.so.2"))) (chmod program 365)) (mkdir-p bindir) (with-directory-excursion bindir (for-each (lambda (tool) (symlink (string-append binutils "/bin/" triplet "-" tool) tool)) (quote ("ar" "ranlib"))) (for-each wrap-program (quote ("gcc" "g++")))))))