(begin (define %build-inputs (quote (("binutils" . "/nix/store/0qky46ax5vnjkcj4czz27ig066n4hdib-binutils-cross-boot0-2.44") ("gcc" . "/nix/store/1dkq8xnw0lr4v8smyz35n3xfw9n8ydmh-gcc-cross-boot0-14.3.0") ("libc" . "/nix/store/07964q6apm4z56kldazgq9xl1v24jglc-glibc-intermediate-2.41") ("bash" . "/nix/store/g9qryy5a9a63y5g1wr67xjlsvdj2aiap-bash-mesboot-5.2.37") ("kernel-headers" . "/nix/store/718va3axqhl2vshjd6nqqqc9nkf2219q-linux-libre-headers-6.12.17")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let* ((binutils (assoc-ref %build-inputs "binutils")) (gcc (assoc-ref %build-inputs "gcc")) (libc (assoc-ref %build-inputs "libc")) (bash (assoc-ref %build-inputs "bash")) (out (assoc-ref %outputs "out")) (bindir (string-append out "/bin")) (triplet "x86_64-guix-linux-gnu")) (define (wrap-program program) (call-with-output-file program (lambda (p) (format p "#!~a/bin/bash\nexec ~a/bin/~a-~a -B~a/lib -Wl,-dynamic-linker -Wl,~a/~a \"$@\"~%" bash gcc triplet program libc libc "/lib/ld-linux-x86-64.so.2"))) (chmod program 365)) (mkdir-p bindir) (with-directory-excursion bindir (for-each (lambda (tool) (symlink (string-append binutils "/bin/" triplet "-" tool) tool)) (quote ("ar" "ranlib"))) (for-each wrap-program (quote ("gcc" "g++")))))))