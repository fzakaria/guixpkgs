(begin (define %build-inputs (quote (("perl" . "/nix/store/vcs9b23vn63zq7ws6rqc5dqann5rkq3s-perl-5.36.0") ("m4" . "/nix/store/krnsnrwrks1208n4yvc4wnr5p20vl3jc-m4-1.4.19") ("source" . "/nix/store/sm3m6c71sxa8rwzk85zllm9xjqrdvdb4-autoconf-2.69.tar.xz") ("guile" . "/nix/store/kmky5r5nnjnwiwih6hl6r4hvx4l0mz35-guile-3.0.9") ("autoconf" . "/nix/store/7n01vc5djj09icv4gp6qwbzlhbql5r6f-autoconf-2.69") ("bash-minimal" . "/nix/store/iy7vbaviimwc19pw7g3a2ggibhfa7rhb-bash-minimal-5.1.16") ("libgc" . "/nix/store/3byq4m469g7ma6hznimm7ii4v5mjggb0-libgc-8.2.4") ("libunistring" . "/nix/store/byp1v7jydj4hqq3dvm11igb0bqj4f0r4-libunistring-1.1")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let ((bin (string-append ((@ (guile) getenv) "out") "/bin")) (autoconf (search-input-file %build-inputs "/bin/autoconf")) (guile (search-input-file %build-inputs "/bin/guile")) (sh (search-input-file %build-inputs "/bin/sh")) (modules ((compose dirname dirname dirname) (search-path %load-path "guix/build/utils.scm")))) (mkdir-p bin) (with-directory-excursion bin (for-each (lambda (file) (unless (string=? (basename file) "autoconf") (symlink file (basename file)))) (find-files (dirname autoconf) ".*"))) (call-with-output-file (string-append bin "/autoconf") (lambda (port) (format port "#!~a\nexport GUILE_LOAD_PATH=\"~a\"\nexport GUILE_LOAD_COMPILED_PATH=\"~a\"\nexec ~a --no-auto-compile \"$0\" \"$@\"\n!#~%" sh modules modules guile) (write (quasiquote (begin (use-modules (guix build utils)) (let ((result (apply system* (unquote autoconf) (cdr (command-line))))) (when (and (file-exists? "configure") (not (file-exists? "/bin/sh"))) (patch-shebang "configure")) (exit (status:exit-val result))))) port))) (chmod (string-append bin "/autoconf") 365))))