(begin (define %build-inputs (quote (("binutils" . "/nix/store/6kwyk5cankv92nzq1zz6wdfcjiprpjqp-binutils-cross-boot0-2.44") ("gcc" . "/nix/store/8sw0fzlh4wmhqj6kd8gwccl049q85xyb-gcc-cross-boot0-14.3.0") ("libc" . "/nix/store/k014xc727dlgshq3jlv7kns92s574dpl-glibc-intermediate-2.41") ("bash" . "/nix/store/wwrl0x00hrn56x5g8mddsgq4smha977b-bash-mesboot-5.2.37") ("kernel-headers" . "/nix/store/h1in1w58da7nj4xsjv9faw542k2x3dn9-linux-libre-headers-6.12.17")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let* ((binutils (assoc-ref %build-inputs "binutils")) (gcc (assoc-ref %build-inputs "gcc")) (libc (assoc-ref %build-inputs "libc")) (bash (assoc-ref %build-inputs "bash")) (out (assoc-ref %outputs "out")) (bindir (string-append out "/bin")) (triplet "x86_64-guix-linux-gnu")) (define (wrap-program program) (call-with-output-file program (lambda (p) (format p "#!~a/bin/bash\nexec ~a/bin/~a-~a -B~a/lib -Wl,-dynamic-linker -Wl,~a/~a \"$@\"~%" bash gcc triplet program libc libc "/lib/ld-linux-x86-64.so.2"))) (chmod program 365)) (mkdir-p bindir) (with-directory-excursion bindir (for-each (lambda (tool) (symlink (string-append binutils "/bin/" triplet "-" tool) tool)) (quote ("ar" "ranlib"))) (for-each wrap-program (quote ("gcc" "g++")))))))