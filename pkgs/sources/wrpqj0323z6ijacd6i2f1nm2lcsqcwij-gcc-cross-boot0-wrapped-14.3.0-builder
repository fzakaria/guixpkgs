(begin (define %build-inputs (quote (("binutils" . "/nix/store/4ybs04byblk6l49wwx8d2bwmfvbcsiyr-binutils-cross-boot0-2.44") ("gcc" . "/nix/store/38c0an7ij6lvk5x8v1h9yhqqpkhlzsdk-gcc-cross-boot0-14.3.0") ("libc" . "/nix/store/6f1n9cmgsbm5s1nhjgsw8xghphrkh9vc-glibc-2.41") ("bash" . "/nix/store/4yim0q7b341c6dfwdjmlf92zpqicmf6y-bash-mesboot-5.2.37") ("kernel-headers" . "/nix/store/jl1az34zra5xbwym4zqipgvxjd0likv2-linux-libre-headers-6.12.17")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let* ((binutils (assoc-ref %build-inputs "binutils")) (gcc (assoc-ref %build-inputs "gcc")) (libc (assoc-ref %build-inputs "libc")) (bash (assoc-ref %build-inputs "bash")) (out (assoc-ref %outputs "out")) (bindir (string-append out "/bin")) (triplet "x86_64-guix-linux-gnu")) (define (wrap-program program) (call-with-output-file program (lambda (p) (format p "#!~a/bin/bash\nexec ~a/bin/~a-~a -B~a/lib -Wl,-dynamic-linker -Wl,~a/~a \"$@\"~%" bash gcc triplet program libc libc "/lib/ld-linux-x86-64.so.2"))) (chmod program 365)) (mkdir-p bindir) (with-directory-excursion bindir (for-each (lambda (tool) (symlink (string-append binutils "/bin/" triplet "-" tool) tool)) (quote ("ar" "ranlib"))) (for-each wrap-program (quote ("gcc" "g++")))))))