(begin (use-modules (guix build texlive-build-system) (guix build union) (guix build utils)) (begin (define %build-inputs (quote (("texlive-bin" . "/nix/store/li5w2zjy31zyd1iamgjjwf1lzihlhsfb-texlive-bin-2025.2") ("ruby" . "/nix/store/hirxqyj5217mdvwxc9hsx75xw4294awq-ruby-2.7.8") ("ruby-hydra-minimal" . "/nix/store/xrj49jkp80lkixv130ccywcya75rvp9y-ruby-hydra-minimal-0.0-0.5abfa37") ("texlive-latex-2025.2-checkout" . "/nix/store/cgsgrsx3q3nx0vb2g1pf1jm1xfvr9dpz-texlive-latex-2025.2-checkout") ("texlive-tex" . "/nix/store/f2lnyvv7vpfj2dwi2apax1j1v317vbwn-texlive-tex-2025.2") ("source" . "/nix/store/r76jpzdc5n7xihljz93yhrlm59kn0ffq-texlive-hyphen-complete-2025.2-checkout") ("tar" . "/nix/store/ib2drldkmhwjdsfsr8a61w2land04b4z-tar-1.35") ("gzip" . "/nix/store/9nwr1gx9a6sd5wq8833a6hrqp7klvgfx-gzip-1.14") ("bzip2" . "/nix/store/nispp88v246z3gbxb0khg7qmhlqsgmr6-bzip2-1.0.8") ("file" . "/nix/store/6h5i05aqb91qv0xrymhx5n0sxhp88a1b-file-5.46") ("diffutils" . "/nix/store/qbdg2k6k59ic660lfigbasa2ksgy7s4g-diffutils-3.12") ("patch" . "/nix/store/s12gja7ydc1gcrfppcpd3qw9p765qi0p-patch-2.7.6") ("findutils" . "/nix/store/z48pja36xgl8cq12ffayj3m0irmrwsma-findutils-4.10.0") ("gawk" . "/nix/store/b90cnx0m3f3bysvyczjky59jgwav1v4f-gawk-5.3.0") ("zstd" . "/nix/store/vlslly0xrb7sdakjjiayhacwxakidscw-zstd-1.5.6") ("sed" . "/nix/store/wgs3sdyxh1vi55hga2a6spcwcql6j5fr-sed-4.9") ("grep" . "/nix/store/r3209yxd42nx6qla820rr2in5j9v0kj4-grep-3.11") ("xz" . "/nix/store/4gh2xab99g04zrcp60zibp4qjhwglj6w-xz-5.4.5") ("coreutils" . "/nix/store/knnb98spvnrgngwg2xrys2dbi01d716m-coreutils-9.1") ("make" . "/nix/store/qak5fjgmg4r54vjbi2cd10v08m357jgc-make-4.4.1") ("bash" . "/nix/store/9m0bgb9d012h7b87hk76shilncbhf100-bash-minimal-5.2.37") ("ld-wrapper" . "/nix/store/c35b733fhdb5i9vy80n8mlp5s3cj02z3-ld-wrapper-0") ("binutils" . "/nix/store/mb9dfx0w21c108lww4ys6y7ggs4s7ha8-binutils-2.44") ("gcc" . "/nix/store/35qzfdh2mc728icgfn87yfad864kwh6m-gcc-14.3.0") ("libc" . "/nix/store/6f1n9cmgsbm5s1nhjgsw8xghphrkh9vc-g