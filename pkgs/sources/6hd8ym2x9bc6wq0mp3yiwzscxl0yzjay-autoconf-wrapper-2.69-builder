(begin (define %build-inputs (quote (("perl" . "/nix/store/2030dfdaq5i1d7wiq0yn20vg8pg239jw-perl-5.36.0") ("m4" . "/nix/store/1n0yyh1q15n681330wy0nzmh9zx7b98i-m4-1.4.19") ("source" . "/nix/store/sm3m6c71sxa8rwzk85zllm9xjqrdvdb4-autoconf-2.69.tar.xz") ("guile" . "/nix/store/d69gxqa3b90rqfg4g2v1zgap72n7apxw-guile-3.0.9") ("autoconf" . "/nix/store/wih2f1xczh9nld9m6182p8jh0vjgdx37-autoconf-2.69") ("bash-minimal" . "/nix/store/kfvkvrvjdcmyjzn59bcs4031hirl4xvr-bash-minimal-5.2.37") ("libgc" . "/nix/store/4h8cfb32pxzswn0vrqbak5bajf8l5jw9-libgc-8.2.8") ("libunistring" . "/nix/store/vvdbr5l0wii2zn12x2x7mk3dys292lsk-libunistring-1.3")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let ((bin (string-append ((@ (guile) getenv) "out") "/bin")) (autoconf (search-input-file %build-inputs "/bin/autoconf")) (guile (search-input-file %build-inputs "/bin/guile")) (sh (search-input-file %build-inputs "/bin/sh")) (modules ((compose dirname dirname dirname) (search-path %load-path "guix/build/utils.scm")))) (mkdir-p bin) (with-directory-excursion bin (for-each (lambda (file) (unless (string=? (basename file) "autoconf") (symlink file (basename file)))) (find-files (dirname autoconf) ".*"))) (call-with-output-file (string-append bin "/autoconf") (lambda (port) (format port "#!~a\nexport GUILE_LOAD_PATH=\"~a\"\nexport GUILE_LOAD_COMPILED_PATH=\"~a\"\nexec ~a --no-auto-compile \"$0\" \"$@\"\n!#~%" sh modules modules guile) (write (quasiquote (begin (use-modules (guix build utils)) (let ((result (apply system* (unquote autoconf) (cdr (command-line))))) (when (and (file-exists? "configure") (not (file-exists? "/bin/sh"))) (patch-shebang "configure")) (exit (status:exit-val result))))) port))) (chmod (string-append bin "/autoconf") 365))))