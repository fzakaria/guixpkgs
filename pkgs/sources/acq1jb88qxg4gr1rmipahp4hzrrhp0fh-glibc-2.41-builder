5qzfdh2mc728icgfn87yfad864kwh6m-gcc-14.3.0") ("libc" . "/nix/store/6f1n9cmgsbm5s1nhjgsw8xghphrkh9vc-glibc-2.41") ("libc:static" . "/nix/store/zrmlcz58j4hyh83kwzb0ig70nwg0m3sy-glibc-2.41-static") ("m4" . "/nix/store/1n0yyh1q15n681330wy0nzmh9zx7b98i-m4-1.4.19") ("kernel-headers" . "/nix/store/jl1az34zra5xbwym4zqipgvxjd0likv2-linux-libre-headers-6.12.17")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")) (cons "debug" ((@ (guile) getenv) "debug")) (cons "static" ((@ (guile) getenv) "static")))) (define %output (assoc-ref %outputs "out")) (gnu-build #:source "/nix/store/7di4ax4vqp11zxgx6xwf0spcklbp3jw7-glibc-2.41.tar.zst" #:system "x86_64-linux" #:build "x86_64-unknown-linux-gnu" #:outputs %outputs #:inputs %build-inputs #:search-paths (quote (("INFOPATH" ("share/info") ":" directory #f) ("PERL5LIB" ("lib/perl5/site_perl") ":" directory #f) ("GUIX_PYTHONPATH" ("lib/python3.11/site-packages") ":" directory #f) ("PYTHONTZPATH" ("share/zoneinfo") ":" directory #f) ("BASH_LOADABLES_PATH" ("lib/bash") ":" directory #f) ("C_INCLUDE_PATH" ("include") ":" directory #f) ("CPLUS_INCLUDE_PATH" ("include/c++" "include") ":" directory #f) ("OBJC_INCLUDE_PATH" ("include") ":" directory #f) ("OBJCPLUS_INCLUDE_PATH" ("include/c++" "include") ":" directory #f) ("LIBRARY_PATH" ("lib" "lib64") ":" directory #f) ("GUIX_LOCPATH" ("lib/locale") ":" directory #f) ("TZDIR" ("share/zoneinfo") #f directory #f))) #:phases (modify-phases %standard-phases (add-before (quote configure) (quote pre-configure) (lambda* (#:key inputs native-inputs outputs #:allow-other-keys) (let* ((out (assoc-ref outputs "out")) (bin (string-append out "/bin")) (bash (or (assoc-ref inputs "static-bash") (assoc-ref native-inputs "static-bash")))) (substitute* "inet/Makefile" (("^\\$\\(inst_sysconfdir\\)/rpc(.*)$" _ suffix) (string-append out "/etc/rpc" suffix "\n")) (("^install-others =.*$") (string-append "install-others = " out "/etc/rpc\n"))) (substitute* "Makeconfig" ((" -lgcc_s") "")) (substitute* "elf/dl-cache.c" (("@STORE_DIRECTORY@") (string-append "\"" (%store-directory) "\""))) (substitute* "sysdeps/posix/system.c" (("#define[[:blank:]]+SHELL_PATH.*$") (format #f "#define SHELL_PATH \"~a/bin/bash\"\n" bash))) (substitute* "libio/iopopen.c" (("/bin/sh") (string-append bash "/bin/sh"))) (substitute* (find-files "." "^paths\\.h$") (("#define[[:blank:]]+_PATH_BSHELL[[:blank:]].*$") (string-append "#define _PATH_BSHELL \"" bash "/bin/sh\"\n"))) (substitute* "malloc/mtrace.pl" (("^#!.*") "") (("exec @PERL@") "exec perl"))))) (add-after (quote install) (quote move-static-libs) (lambda* (#:key outputs #:allow-other-keys) (define (empty-static-library? file) (let ((file (string-append (assoc-ref outputs "out") "/lib/" file))) (and (ar-file? file) (= (stat:size (stat file)) 8)))) (define (static-library? file) (and (string-suffix? ".a" file) (not (string-contains file "_nonshared")) (not (empty-static-library? file)))) (define (linker-script? file) (and (not (ar-file? file)) (not (elf-file? file)))) (let* ((out (assoc-ref outputs "out")) (lib (string-append out "/lib")) (files (scandir lib static-library?)) (empty (scandir lib empty-static-library?)) (static (assoc-ref outputs "static")) (slib (string-append static "/lib"))) (mkdir-p slib) (for-each (lambda (base) (rename-file (string-append lib "/" base) (string-append slib "/" base))) files) (for-each (lambda (base) (copy-file (string-append lib "/" base) (string-append slib "/" base))) empty) (for-each (lambda (ld-script) (substitute* ld-script ((out) static))) (filter linker-script? (map (cut string-append slib "/" <>) files)))))) (add-after (quote install) (quote install-utf8-c-locale) (lambda* (#:key outputs #:allow-other-keys) (let* ((out (assoc-ref outputs "out")) (bin (string-append out "/bin")) (locale (string-append out "/lib/locale/" "2.41"))) (mkdir-p locale) (invoke (string-append bin "/localedef") "--no-archive" "--prefix" locale "-i" "C" "-f" "UTF-8" (string-append locale "/C.UTF-8")))))) #:locale "C.UTF-8" #:separate-from-pid1? #t #:bootstrap-scripts %bootstrap-scripts #:configure-flags (list "--sysconfdir=/etc" (string-append "libc_cv_complocaledir=/run/current-system/locale/" "2.41") (string-append "--with-headers=" (assoc-ref %build-inputs "kernel-headers") "/include") "--enable-kernel=3.2.0" (string-append "BASH_SHELL=" (assoc-ref %build-inputs "bash") "/bin/bash")) #:make-flags (quote ()) #:out-of-source? #t #:tests? #f #:test-target "check" #:parallel-build? #t #:parallel-tests? #t #:patch-shebangs? #t #:license-file-regexp "^(COPYING.*|LICEN[CS]E.*|[Ll]icen[cs]e.*|Copy[Rr]ight(\\.(txt|md))?)$" #:strip-binaries? #t #:validate-runpath? #f #:make-dynamic-linker-cache? #t #:license-file-regexp "^(COPYING.*|LICEN[CS]E.*|[Ll]icen[cs]e.*|Copy[Rr]ight(\\.(txt|md))?)$" #:strip-flags (quote ("--strip-debug")) #:strip-directories (quote ("lib" "lib64" "libexec" "bin" "sbin")))))