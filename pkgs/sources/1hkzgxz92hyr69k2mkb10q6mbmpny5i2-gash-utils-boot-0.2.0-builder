(begin (use-modules (guix build gnu-bootstrap) (guix build gnu-build-system) (guix build utils)) (begin (define %build-inputs (quote (("source" . "/nix/store/w84vfs3nm2rbmcjjazmcgb3wz0mb1531-gash-utils-0.2.0.tar.gz") ("bootar" . "/nix/store/fjd4js7l1mm4351mbjhmf9frv2387zik-bootar-1b") ("gash" . "/nix/store/inajf9nny92m58aifw8m455i2c3g9lfz-gash-boot-0.3.1") ("guile" . "/nix/store/b4r47nm42gcjan5fwafiglhd92zbr7wq-guile-bootstrap-2.0")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (gnu-build #:source "/nix/store/w84vfs3nm2rbmcjjazmcgb3wz0mb1531-gash-utils-0.2.0.tar.gz" #:system "x86_64-linux" #:build "x86_64-unknown-linux-gnu" #:outputs %outputs #:inputs %build-inputs #:search-paths (quote ()) #:phases (modify-phases %standard-phases (add-after (quote unpack) (quote set-load-path) (lambda* (#:key inputs #:allow-other-keys) (let ((gash (assoc-ref inputs "gash"))) (add-to-load-path (string-append gash "/share/guile/site/" (effective-version)))))) (add-before (quote configure) (quote pre-configure) (lambda _ (format #t "Creating gash/commands/testb.scm~%") (copy-file "gash/commands/test.scm" "gash/commands/testb.scm") (substitute* "gash/commands/testb.scm" (("gash commands test") "gash commands testb") (("apply test [(]cdr") "apply test/bracket (cdr")) (for-each (lambda (script) (let ((target (string-append "scripts/" script ".in"))) (format #t "Creating scripts/~a~%" target) (copy-file "scripts/template.in" target) (substitute* target (("@UTILITY@") script)))) (quote ("awk" "basename" "cat" "chmod" "cmp" "command" "compress" "cp" "cut" "diff" "dirname" "env" "expr" "false" "find" "grep" "head" "ln" "ls" "mkdir" "mv" "printf" "pwd" "reboot" "rm" "rmdir" "sed" "sleep" "sort" "tar" "test" "touch" "tr" "true" "uname" "uniq" "wc" "which"))) (format #t "Creating scripts/[.in~%") (copy-file "scripts/template.in" "scripts/[.in") (substitute* "scripts/[.in" (("@UTILITY@") "testb")) (delete-file "scripts/template.in"))) (replace (quote configure) (bootstrap-configure "Gash-Utils" "0.2.0" (quote ("gash" "gash-utils")) "scripts")) (replace (quote build) (bootstrap-build (quote ("gash" "gash-utils")))) (replace (quote install) (bootstrap-install (quote ("gash" "gash-utils")) "scripts")) (add-after (quote install) (quote copy-gash) (lambda* (#:key inputs outputs #:allow-other-keys) (let* ((out (assoc-ref outputs "out")) (moddir (string-append out "/share/guile/site/" (effective-version))) (godir (string-append out "/lib/guile/" (effective-version) "/site-ccache")) (gash (assoc-ref inputs "gash")) (gash-moddir (string-append gash "/share/guile/site/" (effective-version))) (gash-godir (string-append gash "/lib/guile/" (effective-version) "/site-ccache"))) (copy-file (string-append gash-moddir "/gash/compat.scm") (string-append moddir "/gash/compat.scm")) (copy-recursively (string-append gash-moddir "/gash/compat") (string-append moddir "/gash/compat")) (copy-file (string-append gash-godir "/gash/compat.go") (string-append godir "/gash/compat.go")) (copy-recursively (string-append gash-godir "/gash/compat") (string-append godir "/gash/compat"))))) (add-after (quote install) (quote make-echo) (lambda* (#:key inputs outputs #:allow-other-keys) (let* ((out (assoc-ref outputs "out")) (gash (search-input-file inputs "/bin/gash"))) (with-output-to-file (string-append out "/bin/echo") (lambda () (display (string-append "#!" gash "\n")) (newline) (display "echo \"$@\"") (newline))) (chmod (string-append out "/bin/echo") 493))))) #:locale "C.UTF-8" #:separate-from-pid1? #t #:bootstrap-scripts %bootstrap-scripts #:configure-flags (quote ()) #:make-flags (quote ()) #:out-of-source? #f #:tests? #f #:test-target "check" #:parallel-build? #t #:parallel-tests? #t #:patch-shebangs? #t #:license-file-regexp "^(COPYING.*|LICEN[CS]E.*|[Ll]icen[cs]e.*|Copy[Rr]ight(\\.(txt|md))?)$" #:strip-binaries? #t #:validate-runpath? #t #:make-dynamic-linker-cache? #t #:license-file-regexp "^(COPYING.*|LICEN[CS]E.*|