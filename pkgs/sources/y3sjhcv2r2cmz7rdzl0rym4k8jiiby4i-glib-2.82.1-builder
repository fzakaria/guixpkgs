(begin (use-modules (guix build meson-build-system) (guix build utils)) (define build-phases (modify-phases (modify-phases %standard-phases (add-after (quote unpack) (quote set-G_TEST_SRCDIR) (lambda _ (setenv "G_TEST_SRCDIR" (string-append (getcwd) "/gio/tests")))) (add-after (quote unpack) (quote increase-test-timeout) (lambda _ (substitute* "meson.build" (("(test_timeout.*) = ([[:digit:]]+)" all first second) (string-append first " = " second "0"))))) (add-after (quote unpack) (quote disable-failing-tests) (lambda _ (substitute* "gio/tests/meson.build" ((".*'testfilemonitor'.*") "")) (with-directory-excursion "glib/tests" (substitute* (quote ("unix.c" "utils.c")) (("[ \t]*g_test_add_func.*;") ""))) (with-directory-excursion "gio/tests" (substitute* (quote ("contenttype.c" "gdbus-address-get-session.c" "gdbus-server-auth.c" "gdbus-peer.c" "appinfo.c" "desktop-app-info.c")) (("[ \t]*g_test_add_func.*;") "")) (unless (which "update-desktop-database") (substitute* "file.c" (("[ \t]*g_test_add_func.*query-default-handler.*;") ""))) (substitute* (quote ("portal-support-snap.c")) (("g_test_init .*") "return EXIT_SUCCESS;"))))) (add-after (quote unpack) (quote patch-python-references) (lambda* (#:key native-inputs inputs #:allow-other-keys) (substitute* (quote ("gio/gdbus-2.0/codegen/gdbus-codegen.in" "glib/gtester-report.in" "gobject/glib-genmarshal.in" "gobject/glib-mkenums.in")) (("@PYTHON@") (search-input-file (or native-inputs inputs) (string-append "/bin/python" "3.11")))))) (add-before (quote check) (quote pre-check) (lambda* (#:key native-inputs inputs outputs #:allow-other-keys) (setenv "TZDIR" (search-input-directory (or native-inputs inputs) "share/zoneinfo")) (setenv "HOME" (getcwd)) (setenv "XDG_CACHE_HOME" (getcwd)))) (add-after (quote install) (quote move-static-libraries) (lambda _ (mkdir-p (string-append ((@ (guile) getenv) "static") "/lib")) (for-each (lambda (a) (rename-file a (string-append ((@ (guile) getenv) "static") "/lib/" (basename a)))) (find-f