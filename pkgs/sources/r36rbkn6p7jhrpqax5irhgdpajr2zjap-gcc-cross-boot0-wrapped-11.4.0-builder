(begin (define %build-inputs (quote (("binutils" . "/nix/store/0pzj3j8xlq4xxwfwca8bwdylvr5jw833-binutils-cross-boot0-2.41") ("gcc" . "/nix/store/3yp9fw3vpqh7jczipqk81365gbpiyaag-gcc-cross-boot0-11.4.0") ("libc" . "/nix/store/xxbly5717sxyshn8akzh0mi9vw4mbppp-glibc-2.39") ("bash" . "/nix/store/zdr3gjhgb0va9jm2a4wk760xha4n74yc-bash-mesboot-5.1.16") ("kernel-headers" . "/nix/store/mm2arizx2wqdblpzjin8gzd7nkf8xqzj-linux-libre-headers-5.15.49")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils)) (let* ((binutils (assoc-ref %build-inputs "binutils")) (gcc (assoc-ref %build-inputs "gcc")) (libc (assoc-ref %build-inputs "libc")) (bash (assoc-ref %build-inputs "bash")) (out (assoc-ref %outputs "out")) (bindir (string-append out "/bin")) (triplet "x86_64-guix-linux-gnu")) (define (wrap-program program) (call-with-output-file program (lambda (p) (format p "#!~a/bin/bash\nexec ~a/bin/~a-~a -B~a/lib -Wl,-dynamic-linker -Wl,~a/~a \"$@\"~%" bash gcc triplet program libc libc "/lib/ld-linux-x86-64.so.2"))) (chmod program 365)) (mkdir-p bindir) (with-directory-excursion bindir (for-each (lambda (tool) (symlink (string-append binutils "/bin/" triplet "-" tool) tool)) (quote ("ar" "ranlib"))) (for-each wrap-program (quote ("gcc" "g++")))))))