(begin (define %build-inputs (quote (("tar" . "/nix/store/fadpfr806vdd818kvcj2w28qr4307d7j-tar-1.34") ("xz" . "/nix/store/alp3qs8mqm7x2hpsf77kimlfvmp0xm3i-xz-5.4.5") ("source" . "/nix/store/kgjkamp8cjpy9m9mck2v3i0cjsrnhl1j-netbase_5.3.tar.xz")))) (define %outputs (list (cons "out" ((@ (guile) getenv) "out")))) (define %output (assoc-ref %outputs "out")) (begin (use-modules (guix build utils) (srfi srfi-26)) (let* ((source (assoc-ref %build-inputs "source")) (tar (assoc-ref %build-inputs "tar")) (xz (assoc-ref %build-inputs "xz")) (output (assoc-ref %outputs "out")) (etc (string-append output "/etc"))) (setenv "PATH" (string-append xz "/bin")) (invoke (string-append tar "/bin/tar") "xvf" source) (chdir "netbase-5.3") (mkdir-p etc) (for-each copy-file (quote ("etc-services" "etc-protocols" "etc-rpc")) (map (cut string-append etc "/" <>) (quote ("services" "protocols" "rpc")))) #t)))